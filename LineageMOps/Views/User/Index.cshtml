@model LineageMOps.Models.ViewModels.PaginatedList<LineageMOps.Models.Domain.Account>
@{
    ViewData["Title"] = "유저 관리";
    string? q = ViewBag.Query;
    string? server = ViewBag.Server;
    LineageMOps.Models.Domain.AccountStatus? status = ViewBag.Status;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="mb-0 fw-bold">유저 목록</h5>
    <span class="text-muted" style="font-size:0.85rem;">총 <strong>@Model.TotalCount</strong>명</span>
</div>

<!-- Search Form -->
<div class="card mb-3">
    <div class="card-body py-3">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-md-4">
                <label class="form-label small fw-semibold text-muted">검색</label>
                <input type="text" name="q" value="@q" class="form-control form-control-sm"
                       placeholder="계정ID / 이름 / 이메일" />
            </div>
            <div class="col-md-3">
                <label class="form-label small fw-semibold text-muted">서버</label>
                <select name="server" class="form-select form-select-sm">
                    <option value="">전체 서버</option>
                    @foreach (var s in new[] { "켄라우헬","바츠","기란","오렌","아덴","글루디오","디온" })
                    {
                        <option value="@s" selected="@(server == s ? "selected" : null)">@s</option>
                    }
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label small fw-semibold text-muted">상태</label>
                <select name="status" class="form-select form-select-sm">
                    <option value="">전체 상태</option>
                    @foreach (LineageMOps.Models.Domain.AccountStatus st in Enum.GetValues(typeof(LineageMOps.Models.Domain.AccountStatus)))
                    {
                        var label = st switch
                        {
                            LineageMOps.Models.Domain.AccountStatus.Active => "정상",
                            LineageMOps.Models.Domain.AccountStatus.Suspended => "일시정지",
                            LineageMOps.Models.Domain.AccountStatus.Banned => "영구정지",
                            LineageMOps.Models.Domain.AccountStatus.Dormant => "휴면",
                            _ => st.ToString()
                        };
                        <option value="@st" selected="@(status == st ? "selected" : null)">@label</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-primary btn-sm w-100">
                    <i class="bi bi-search me-1"></i>검색
                </button>
            </div>
        </form>
    </div>
</div>

<!-- Table -->
<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th class="ps-3">계정ID</th>
                        <th>이름</th>
                        <th>서버</th>
                        <th>가입일</th>
                        <th>마지막 접속</th>
                        <th>상태</th>
                        <th>제재수</th>
                        <th class="text-center">관리</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var acc in Model.Items)
                    {
                        var (badgeColor, statusText) = acc.Status switch
                        {
                            LineageMOps.Models.Domain.AccountStatus.Active => ("success", "정상"),
                            LineageMOps.Models.Domain.AccountStatus.Suspended => ("warning", "일시정지"),
                            LineageMOps.Models.Domain.AccountStatus.Banned => ("danger", "영구정지"),
                            LineageMOps.Models.Domain.AccountStatus.Dormant => ("secondary", "휴면"),
                            _ => ("secondary", acc.Status.ToString())
                        };
                        <tr>
                            <td class="ps-3">
                                <a href="/User/Detail/@acc.Id" class="fw-semibold text-decoration-none">@acc.UserId</a>
                            </td>
                            <td>@acc.UserName</td>
                            <td><span class="badge bg-dark">@acc.Server</span></td>
                            <td class="text-muted" style="font-size:0.82rem;">@acc.RegisteredAt.ToString("yyyy-MM-dd")</td>
                            <td class="text-muted" style="font-size:0.82rem;">@acc.LastLoginAt.ToString("yyyy-MM-dd HH:mm")</td>
                            <td><span class="badge bg-@badgeColor">@statusText</span></td>
                            <td class="text-center">
                                @if (acc.Sanctions.Any())
                                {
                                    <span class="badge bg-danger">@acc.Sanctions.Count</span>
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            </td>
                            <td class="text-center">
                                <a href="/User/Detail/@acc.Id" class="btn btn-xs btn-outline-primary" style="font-size:0.75rem;padding:2px 8px;">상세</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Pagination -->
@if (Model.TotalPages > 1)
{
    <nav class="mt-3 d-flex justify-content-center">
        <ul class="pagination pagination-sm">
            <li class="page-item @(!Model.HasPreviousPage ? "disabled" : "")">
                <a class="page-link" href="?q=@q&server=@server&status=@status&page=@(Model.PageIndex - 1)">이전</a>
            </li>
            @for (int i = Math.Max(1, Model.PageIndex - 2); i <= Math.Min(Model.TotalPages, Model.PageIndex + 2); i++)
            {
                <li class="page-item @(i == Model.PageIndex ? "active" : "")">
                    <a class="page-link" href="?q=@q&server=@server&status=@status&page=@i">@i</a>
                </li>
            }
            <li class="page-item @(!Model.HasNextPage ? "disabled" : "")">
                <a class="page-link" href="?q=@q&server=@server&status=@status&page=@(Model.PageIndex + 1)">다음</a>
            </li>
        </ul>
    </nav>
}
