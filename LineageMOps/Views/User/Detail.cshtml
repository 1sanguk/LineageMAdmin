@model LineageMOps.Models.ViewModels.UserDetailViewModel
@{
    ViewData["Title"] = $"유저 상세 - {Model.Account.UserId}";
    var (badgeColor, statusText) = Model.Account.Status switch
    {
        LineageMOps.Models.Domain.AccountStatus.Active => ("success", "정상"),
        LineageMOps.Models.Domain.AccountStatus.Suspended => ("warning", "일시정지"),
        LineageMOps.Models.Domain.AccountStatus.Banned => ("danger", "영구정지"),
        LineageMOps.Models.Domain.AccountStatus.Dormant => ("secondary", "휴면"),
        _ => ("secondary", Model.Account.Status.ToString())
    };
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <a href="/User" class="btn btn-sm btn-outline-secondary me-2"><i class="bi bi-arrow-left me-1"></i>목록</a>
        <span class="fw-bold fs-5">@Model.Account.UserId</span>
        <span class="badge bg-@badgeColor ms-2">@statusText</span>
    </div>
    <a href="/User/Sanction/@Model.Account.Id" class="btn btn-danger btn-sm">
        <i class="bi bi-shield-exclamation me-1"></i>제재 처리
    </a>
</div>

<div class="row g-3">
    <!-- Account Info -->
    <div class="col-md-5">
        <div class="card h-100">
            <div class="card-header"><i class="bi bi-person-fill me-2"></i>계정 정보</div>
            <div class="card-body">
                <table class="table table-sm mb-0">
                    <tbody>
                        <tr><th style="width:35%;font-size:0.82rem;" class="text-muted">계정 ID</th><td class="fw-semibold">@Model.Account.UserId</td></tr>
                        <tr><th class="text-muted">이름</th><td>@Model.Account.UserName</td></tr>
                        <tr><th class="text-muted">이메일</th><td>@Model.Account.Email</td></tr>
                        <tr><th class="text-muted">서버</th><td><span class="badge bg-dark">@Model.Account.Server</span></td></tr>
                        <tr><th class="text-muted">가입일</th><td>@Model.Account.RegisteredAt.ToString("yyyy-MM-dd HH:mm")</td></tr>
                        <tr><th class="text-muted">마지막 접속</th><td>@Model.Account.LastLoginAt.ToString("yyyy-MM-dd HH:mm")</td></tr>
                        <tr><th class="text-muted">최근 IP</th><td><code>@Model.Account.IpAddress</code></td></tr>
                        <tr><th class="text-muted">상태</th><td><span class="badge bg-@badgeColor">@statusText</span></td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Characters -->
    <div class="col-md-7">
        <div class="card h-100">
            <div class="card-header"><i class="bi bi-joystick me-2"></i>보유 캐릭터 (@Model.Characters.Count)</div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-sm table-hover mb-0">
                        <thead>
                            <tr>
                                <th class="ps-3">캐릭터명</th>
                                <th>직업</th>
                                <th>레벨</th>
                                <th>혈맹</th>
                                <th>아데나</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var ch in Model.Characters)
                            {
                                var className = ch.Class switch
                                {
                                    LineageMOps.Models.Domain.CharacterClass.Knight => "군주",
                                    LineageMOps.Models.Domain.CharacterClass.DarkKnight => "기사",
                                    LineageMOps.Models.Domain.CharacterClass.Elf => "요정",
                                    LineageMOps.Models.Domain.CharacterClass.Wizard => "마법사",
                                    LineageMOps.Models.Domain.CharacterClass.DarkElf => "다크엘프",
                                    LineageMOps.Models.Domain.CharacterClass.DragonKnight => "드래곤나이트",
                                    LineageMOps.Models.Domain.CharacterClass.Illusionist => "환술사",
                                    _ => ch.Class.ToString()
                                };
                                <tr>
                                    <td class="ps-3 fw-semibold">@ch.Name</td>
                                    <td><span class="badge bg-secondary">@className</span></td>
                                    <td>Lv.<strong>@ch.Level</strong></td>
                                    <td class="text-muted" style="font-size:0.82rem;">@(string.IsNullOrEmpty(ch.ClanName) ? "-" : ch.ClanName)</td>
                                    <td class="text-muted" style="font-size:0.82rem;">@ch.Adena.ToString("N0")</td>
                                    <td><a href="/GameData/Detail/@ch.Id" class="btn btn-xs btn-outline-info" style="font-size:0.72rem;padding:1px 6px;">상세</a></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- Sanction History -->
    <div class="col-12">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span><i class="bi bi-shield-exclamation me-2"></i>제재 이력 (@Model.SanctionHistory.Count)</span>
                <a href="/User/Sanction/@Model.Account.Id" class="btn btn-danger btn-sm">
                    <i class="bi bi-plus-circle me-1"></i>제재 추가
                </a>
            </div>
            <div class="card-body p-0">
                @if (!Model.SanctionHistory.Any())
                {
                    <div class="text-center text-muted py-4">
                        <i class="bi bi-shield-check" style="font-size:2rem;"></i>
                        <p class="mt-2 mb-0">제재 이력이 없습니다.</p>
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-sm table-hover mb-0">
                            <thead>
                                <tr>
                                    <th class="ps-3">유형</th>
                                    <th>사유</th>
                                    <th>시작일</th>
                                    <th>종료일</th>
                                    <th>처리자</th>
                                    <th>상태</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var s in Model.SanctionHistory)
                                {
                                    var (sBadge, sText) = s.Type switch
                                    {
                                        LineageMOps.Models.Domain.SanctionType.ChatBan => ("info", "채팅금지"),
                                        LineageMOps.Models.Domain.SanctionType.LoginRestriction => ("warning", "접속제한"),
                                        LineageMOps.Models.Domain.SanctionType.PermanentBan => ("danger", "영구정지"),
                                        _ => ("secondary", s.Type.ToString())
                                    };
                                    <tr>
                                        <td class="ps-3"><span class="badge bg-@sBadge">@sText</span></td>
                                        <td>@s.Reason</td>
                                        <td class="text-muted" style="font-size:0.82rem;">@s.StartDate.ToString("yyyy-MM-dd")</td>
                                        <td class="text-muted" style="font-size:0.82rem;">@(s.EndDate.HasValue ? s.EndDate.Value.ToString("yyyy-MM-dd") : "영구")</td>
                                        <td class="text-muted" style="font-size:0.82rem;">@s.OperatorId</td>
                                        <td>
                                            @if (s.IsActive)
                                            {
                                                <span class="badge bg-danger">적용 중</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-light text-dark">종료</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
