@model LineageMOps.Models.ViewModels.SanctionFormViewModel
@{
    ViewData["Title"] = $"제재 처리 - {Model.UserId}";
}

<div class="row justify-content-center">
    <div class="col-md-7">
        <div class="mb-3">
            <a href="/User/Detail/@Model.AccountId" class="btn btn-sm btn-outline-secondary">
                <i class="bi bi-arrow-left me-1"></i>상세로 돌아가기
            </a>
        </div>

        <div class="card">
            <div class="card-header">
                <i class="bi bi-shield-exclamation me-2 text-danger"></i>
                제재 처리 — <strong>@Model.UserId</strong>
            </div>
            <div class="card-body">
                <div class="alert alert-warning py-2" style="font-size:0.85rem;">
                    <i class="bi bi-exclamation-triangle-fill me-1"></i>
                    제재 처리는 즉시 적용되며, 운영자 감사 로그에 기록됩니다.
                </div>

                <form method="post" action="/User/Sanction">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="AccountId" value="@Model.AccountId" />
                    <input type="hidden" name="UserId" value="@Model.UserId" />

                    <div class="mb-3">
                        <label class="form-label fw-semibold">제재 유형 <span class="text-danger">*</span></label>
                        <div class="d-flex gap-3">
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="Type" value="@LineageMOps.Models.Domain.SanctionType.ChatBan"
                                       id="typeChatBan" checked="checked" onchange="toggleDuration(true)" />
                                <label class="form-check-label" for="typeChatBan">
                                    <span class="badge bg-info">채팅 금지</span>
                                </label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="Type" value="@LineageMOps.Models.Domain.SanctionType.LoginRestriction"
                                       id="typeLogin" onchange="toggleDuration(true)" />
                                <label class="form-check-label" for="typeLogin">
                                    <span class="badge bg-warning text-dark">접속 제한</span>
                                </label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="Type" value="@LineageMOps.Models.Domain.SanctionType.PermanentBan"
                                       id="typeBan" onchange="toggleDuration(false)" />
                                <label class="form-check-label" for="typeBan">
                                    <span class="badge bg-danger">영구 정지</span>
                                </label>
                            </div>
                        </div>
                    </div>

                    <div class="mb-3" id="durationGroup">
                        <label class="form-label fw-semibold">제재 기간 (일)</label>
                        <div class="d-flex gap-2 align-items-center">
                            <input type="number" name="DurationDays" class="form-control" style="max-width:120px;"
                                   value="7" min="1" max="365" />
                            <div class="btn-group btn-group-sm">
                                <button type="button" class="btn btn-outline-secondary" onclick="setDays(1)">1일</button>
                                <button type="button" class="btn btn-outline-secondary" onclick="setDays(3)">3일</button>
                                <button type="button" class="btn btn-outline-secondary" onclick="setDays(7)">7일</button>
                                <button type="button" class="btn btn-outline-secondary" onclick="setDays(30)">30일</button>
                            </div>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-semibold">제재 사유 <span class="text-danger">*</span></label>
                        <textarea name="Reason" class="form-control" rows="4" required
                                  placeholder="제재 사유를 상세히 입력하세요. 예: 핵 프로그램 사용 확인 (2026-03-04 14:32, 기란 서버)"></textarea>
                        <div class="form-text">최소 10자 이상 입력을 권장합니다.</div>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-danger px-4">
                            <i class="bi bi-shield-exclamation me-1"></i>제재 적용
                        </button>
                        <a href="/User/Detail/@Model.AccountId" class="btn btn-outline-secondary">취소</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    function toggleDuration(show) {
        document.getElementById('durationGroup').style.display = show ? '' : 'none';
    }
    function setDays(n) {
        document.querySelector('input[name="DurationDays"]').value = n;
    }
</script>
}
