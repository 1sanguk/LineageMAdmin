@model List<LineageMOps.Models.Domain.AdminLog>
@{
    ViewData["Title"] = "어드민 로그";
}

<div class="card">
    <div class="card-header d-flex align-items-center justify-content-between">
        <span><i class="bi bi-shield-lock me-2"></i>어드민 로그</span>
        <span class="text-muted" style="font-size:0.82rem;">최근 @Model.Count 건</span>
    </div>
    <div class="card-body p-0">
        @if (!Model.Any())
        {
            <div class="text-center text-muted py-5">운영 기록이 없습니다.</div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover table-sm mb-0">
                    <thead>
                        <tr>
                            <th class="ps-3" style="width:140px;">시간</th>
                            <th style="width:130px;">액션</th>
                            <th style="width:200px;">대상</th>
                            <th>변경 내용</th>
                            <th style="width:90px;">운영자</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var log in Model)
                        {
                            var actionBadge = log.Action switch
                            {
                                var a when a.Contains("제재") => "danger",
                                var a when a.Contains("삭제") => "warning",
                                var a when a.Contains("등록") => "success",
                                var a when a.Contains("수정") => "primary",
                                _ => "secondary"
                            };
                            <tr>
                                <td class="ps-3 text-muted" style="font-size:0.78rem;white-space:nowrap;">
                                    @log.CreatedAt.ToString("yyyy-MM-dd HH:mm:ss")
                                </td>
                                <td>
                                    <span class="badge bg-@actionBadge" style="font-size:0.72rem;">@log.Action</span>
                                </td>
                                <td style="font-size:0.82rem;">@log.Target</td>
                                <td class="text-muted" style="font-size:0.82rem;">
                                    @if (!string.IsNullOrEmpty(log.Detail))
                                    {
                                        @log.Detail
                                    }
                                    else
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                </td>
                                <td>
                                    <code style="font-size:0.75rem;">@log.OperatorId</code>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
