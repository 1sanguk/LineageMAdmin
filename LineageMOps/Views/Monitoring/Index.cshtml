@model LineageMOps.Models.ViewModels.PaginatedList<LineageMOps.Models.Domain.ServerLog>
@{
    ViewData["Title"] = "모니터링 / 로그";
    var servers = ViewBag.Servers as List<LineageMOps.Models.Domain.ServerStatus> ?? new();
LineageMOps.Models.Domain.LogType? logType = ViewBag.Type;
    string? server = ViewBag.Server;
    string? search = ViewBag.Search;
}

<!-- Server Status Row -->
<div class="row g-2 mb-4">
    @foreach (var s in servers)
    {
        var (stateClass, stateBadge, stateText) = s.State switch
        {
            LineageMOps.Models.Domain.ServerState.Online => ("online", "success", "정상"),
            LineageMOps.Models.Domain.ServerState.Warning => ("warning", "warning", "주의"),
            LineageMOps.Models.Domain.ServerState.Maintenance => ("maintenance", "secondary", "점검"),
            _ => ("offline", "danger", "오프라인")
        };
        var cpuColor = s.CpuUsage >= 85 ? "danger" : s.CpuUsage >= 60 ? "warning" : "success";
        var memColor = s.MemoryUsage >= 85 ? "danger" : s.MemoryUsage >= 60 ? "warning" : "success";
        <div class="col-md-3 col-lg-auto flex-grow-1">
            <div class="card server-card p-3">
                <div class="d-flex justify-content-between align-items-start mb-1">
                    <div>
                        <span class="status-dot @stateClass me-1"></span>
                        <strong style="font-size:0.88rem;">@s.DisplayName</strong>
                    </div>
                    <span class="badge bg-@stateBadge">@stateText</span>
                </div>
                <div style="font-size:0.75rem;" class="text-muted">
                    <i class="bi bi-people me-1"></i>@s.CurrentPlayers.ToString("N0")명
                </div>
                <div class="d-flex gap-2 mt-1" style="font-size:0.72rem;">
                    <span>
                        CPU
                        <span class="text-@cpuColor fw-semibold">@s.CpuUsage.ToString("0.0")%</span>
                    </span>
                    <span>
                        MEM
                        <span class="text-@memColor fw-semibold">@s.MemoryUsage.ToString("0.0")%</span>
                    </span>
                </div>
            </div>
        </div>
    }
</div>

<!-- Log Filter -->
<div class="card mb-3">
    <div class="card-body py-3">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-md-3">
                <label class="form-label small fw-semibold text-muted">검색</label>
                <input type="text" name="search" value="@search" class="form-control form-control-sm" placeholder="메시지 / 유저ID" />
            </div>
            <div class="col-md-2">
                <label class="form-label small fw-semibold text-muted">로그 유형</label>
                <select name="type" class="form-select form-select-sm">
                    <option value="">전체</option>
                    @foreach (LineageMOps.Models.Domain.LogType t in Enum.GetValues(typeof(LineageMOps.Models.Domain.LogType)))
                    {
                        var label = t switch
                        {
                            LineageMOps.Models.Domain.LogType.Login => "접속",
                            LineageMOps.Models.Domain.LogType.Logout => "종료",
                            LineageMOps.Models.Domain.LogType.Chat => "채팅",
                            LineageMOps.Models.Domain.LogType.Trade => "거래",
                            LineageMOps.Models.Domain.LogType.System => "시스템",
                            LineageMOps.Models.Domain.LogType.Audit => "감사",
                            LineageMOps.Models.Domain.LogType.Error => "오류",
                            _ => t.ToString()
                        };
                        <option value="@t" selected="@(logType == t ? "selected" : null)">@label</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label small fw-semibold text-muted">서버</label>
                <select name="server" class="form-select form-select-sm">
                    <option value="">전체</option>
                    @foreach (var sv in new[] { "켄라우헬","바츠","기란","오렌","아덴","글루디오","디온" })
                    {
                        <option value="@sv" selected="@(server == sv ? "selected" : null)">@sv</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-primary btn-sm w-100"><i class="bi bi-search me-1"></i>검색</button>
            </div>
            <div class="col-md-3 text-end">
                <span class="text-muted" style="font-size:0.82rem;">
                    총 <strong>@Model.TotalCount</strong>개 로그
                </span>
            </div>
        </form>
    </div>
</div>

<!-- Log Table -->
<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover table-sm mb-0">
                <thead>
                    <tr>
                        <th class="ps-3" style="width:140px;">시간</th>
                        <th style="width:80px;">서버</th>
                        <th style="width:70px;">유형</th>
                        <th style="width:60px;">레벨</th>
                        <th>메시지</th>
                        <th style="width:100px;">유저ID</th>
                        <th style="width:110px;">IP</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var log in Model.Items)
                    {
                        var (typeBadge, typeText) = log.Type switch
                        {
                            LineageMOps.Models.Domain.LogType.Login => ("primary", "접속"),
                            LineageMOps.Models.Domain.LogType.Logout => ("secondary", "종료"),
                            LineageMOps.Models.Domain.LogType.Chat => ("info", "채팅"),
                            LineageMOps.Models.Domain.LogType.Trade => ("success", "거래"),
                            LineageMOps.Models.Domain.LogType.System => ("light", "시스템"),
                            LineageMOps.Models.Domain.LogType.Audit => ("warning", "감사"),
                            LineageMOps.Models.Domain.LogType.Error => ("danger", "오류"),
                            _ => ("secondary", log.Type.ToString())
                        };
                        var levelStyle = log.Level switch
                        {
                            LineageMOps.Models.Domain.LogLevel.Warning => "color:#b45309",
                            LineageMOps.Models.Domain.LogLevel.Error => "color:#dc2626",
                            LineageMOps.Models.Domain.LogLevel.Critical => "color:#7c3aed;font-weight:600",
                            _ => "color:#374151"
                        };
                        <tr>
                            <td class="ps-3 text-muted" style="font-size:0.78rem;white-space:nowrap;">
                                @log.Timestamp.ToString("MM-dd HH:mm:ss")
                            </td>
                            <td><span class="badge bg-dark" style="font-size:0.68rem;">@log.Server</span></td>
                            <td><span class="badge bg-@typeBadge" style="font-size:0.68rem;">@typeText</span></td>
                            <td>
                                @{
                                    var levelText = log.Level switch
                                    {
                                        LineageMOps.Models.Domain.LogLevel.Info => "INFO",
                                        LineageMOps.Models.Domain.LogLevel.Warning => "WARN",
                                        LineageMOps.Models.Domain.LogLevel.Error => "ERR",
                                        LineageMOps.Models.Domain.LogLevel.Critical => "CRIT",
                                        _ => log.Level.ToString()
                                    };
                                }
                                <span style="font-size:0.72rem;@levelStyle">@levelText</span>
                            </td>
                            <td style="font-size:0.82rem;@levelStyle">
                                @log.Message
                                @if (!string.IsNullOrEmpty(log.Detail))
                                {
                                    <small class="text-muted ms-1">(@log.Detail)</small>
                                }
                            </td>
                            <td class="text-muted" style="font-size:0.78rem;">
                                @if (!string.IsNullOrEmpty(log.UserId))
                                {
                                    <a href="/User?q=@log.UserId" class="text-decoration-none text-primary">@log.UserId</a>
                                }
                            </td>
                            <td class="text-muted" style="font-size:0.78rem;">
                                @if (!string.IsNullOrEmpty(log.IpAddress))
                                {
                                    <code style="font-size:0.72rem;">@log.IpAddress</code>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@if (Model.TotalPages > 1)
{
    <nav class="mt-3 d-flex justify-content-center">
        <ul class="pagination pagination-sm">
            <li class="page-item @(!Model.HasPreviousPage ? "disabled" : "")">
                <a class="page-link" href="?type=@logType&server=@server&search=@search&page=@(Model.PageIndex - 1)">이전</a>
            </li>
            @for (int i = Math.Max(1, Model.PageIndex - 2); i <= Math.Min(Model.TotalPages, Model.PageIndex + 2); i++)
            {
                <li class="page-item @(i == Model.PageIndex ? "active" : "")">
                    <a class="page-link" href="?type=@logType&server=@server&search=@search&page=@i">@i</a>
                </li>
            }
            <li class="page-item @(!Model.HasNextPage ? "disabled" : "")">
                <a class="page-link" href="?type=@logType&server=@server&search=@search&page=@(Model.PageIndex + 1)">다음</a>
            </li>
        </ul>
    </nav>
}

