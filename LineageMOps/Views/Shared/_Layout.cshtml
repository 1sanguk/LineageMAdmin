<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - 리니지M 운영툴</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.8/css/dataTables.bootstrap5.min.css" />
    <style>
        :root {
            --sidebar-width: 240px;
            --sidebar-bg: #0f1923;
            --sidebar-hover: #1e2d3d;
            --sidebar-active: #1a6fc4;
            --ncsoft-gold: #c8a951;
        }
        body { background: #f0f2f5; font-family: 'Malgun Gothic', 'Apple SD Gothic Neo', sans-serif; }

        #sidebar {
            width: var(--sidebar-width);
            min-height: 100vh;
            background: var(--sidebar-bg);
            position: fixed;
            top: 0; left: 0;
            z-index: 100;
            overflow-y: auto;
        }
        #sidebar .brand { padding: 16px 20px; border-bottom: 1px solid #1e2d3d; }
        #sidebar .brand h5 { color: var(--ncsoft-gold); font-weight: 700; margin: 0; font-size: 0.95rem; letter-spacing: 0.5px; }
        #sidebar .brand small { color: #6c8096; font-size: 0.72rem; }
        #sidebar .nav-section { padding: 8px 0; border-bottom: 1px solid #1a2535; }
        #sidebar .nav-label { color: #4a6480; font-size: 0.68rem; font-weight: 700; letter-spacing: 1.5px; text-transform: uppercase; padding: 10px 20px 4px; }
        #sidebar .nav-link { color: #8fa8c0; padding: 8px 20px; display: flex; align-items: center; gap: 10px; font-size: 0.875rem; border-radius: 0; transition: all 0.15s; }
        #sidebar .nav-link:hover { background: var(--sidebar-hover); color: #d0e4f7; }
        #sidebar .nav-link.active { background: var(--sidebar-active); color: #fff; font-weight: 500; }
        #sidebar .nav-link i { width: 18px; text-align: center; font-size: 1rem; }

        /* 대메뉴 (접힘/펼침) */
        #sidebar .nav-group-toggle {
            color: #8fa8c0; padding: 9px 20px; display: flex; align-items: center; gap: 10px;
            font-size: 0.875rem; cursor: pointer; user-select: none; transition: all 0.15s;
            border-radius: 0;
        }
        #sidebar .nav-group-toggle:hover { background: var(--sidebar-hover); color: #d0e4f7; }
        #sidebar .nav-group-toggle.open { color: #d0e4f7; }
        #sidebar .nav-group-toggle i.toggle-icon { margin-left: auto; font-size: 0.75rem; transition: transform 0.2s; }
        #sidebar .nav-group-toggle.open i.toggle-icon { transform: rotate(90deg); }
        #sidebar .nav-group-toggle i:first-child { width: 18px; text-align: center; font-size: 1rem; }
        /* 하위 메뉴 */
        #sidebar .nav-sub { background: #0a1319; overflow: hidden; }
        #sidebar .nav-sub .nav-link { padding: 7px 20px 7px 48px; font-size: 0.83rem; color: #6c8096; }
        #sidebar .nav-sub .nav-link:hover { background: var(--sidebar-hover); color: #d0e4f7; }
        #sidebar .nav-sub .nav-link.active { background: var(--sidebar-active); color: #fff; font-weight: 500; }

        #main-content { margin-left: var(--sidebar-width); min-height: 100vh; display: flex; flex-direction: column; }
        #topbar { height: 56px; background: #fff; border-bottom: 1px solid #e0e5eb; padding: 0 24px; display: flex; align-items: center; justify-content: space-between; position: sticky; top: 0; z-index: 50; }
        #topbar .page-title { font-size: 1rem; font-weight: 600; color: #1a2535; margin: 0; }
        #topbar .operator-info { font-size: 0.8rem; color: #6c8096; display: flex; align-items: center; gap: 8px; }

        .page-body { padding: 24px; flex: 1; }
        .stat-card { border: none; border-radius: 10px; overflow: hidden; }
        .stat-card .card-body { padding: 20px 24px; }
        .stat-card .stat-value { font-size: 2rem; font-weight: 700; line-height: 1; }
        .stat-card .stat-label { font-size: 0.78rem; opacity: 0.75; margin-top: 4px; }

        .server-card { border: none; border-radius: 8px; box-shadow: 0 1px 4px rgba(0,0,0,0.08); }
        .status-dot { width: 10px; height: 10px; border-radius: 50%; display: inline-block; }
        .status-dot.online { background: #22c55e; box-shadow: 0 0 6px #22c55e; }
        .status-dot.warning { background: #f59e0b; box-shadow: 0 0 6px #f59e0b; animation: blink 1.5s infinite; }
        .status-dot.maintenance { background: #6b7280; }
        .status-dot.offline { background: #ef4444; }
        @@keyframes blink { 0%, 100% { opacity: 1; } 50% { opacity: 0.3; } }

        .table th { font-size: 0.8rem; font-weight: 600; color: #6c8096; text-transform: uppercase; letter-spacing: 0.5px; border-top: none; }
        .table td { vertical-align: middle; font-size: 0.875rem; }
        .table-hover tbody tr:hover { background: #f0f7ff; }

        .alert-toast { position: fixed; top: 70px; right: 20px; z-index: 9999; min-width: 280px; animation: slideIn 0.3s ease; }
        @@keyframes slideIn { from { transform: translateX(120%); } to { transform: translateX(0); } }

        .card { border: none; box-shadow: 0 1px 4px rgba(0,0,0,0.07); border-radius: 10px; }
        .card-header { background: #fff; border-bottom: 1px solid #f0f2f5; font-weight: 600; padding: 14px 20px; }
    </style>
</head>
<body>
    <nav id="sidebar">
        <div class="brand">
            <h5><i class="bi bi-shield-fill me-1"></i> LineageM OPS</h5>
            <small>리니지M 운영 관리 시스템</small>
        </div>
        <div class="nav-section">
            <div class="nav-label">Overview</div>
            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" ? "active" : "")" href="/Dashboard">
                <i class="bi bi-speedometer2"></i> 대시보드
            </a>
        </div>
        @{
            var currentCtrl = ViewContext.RouteData.Values["controller"]?.ToString();
            var isUserGroup  = currentCtrl == "User" || currentCtrl == "GameData";
            var isAdminGroup = currentCtrl == "Event";
            var isClanGroup  = currentCtrl == "Clan";
        }
        <div class="nav-section">
            <div class="nav-label">운영자 관리</div>
            <div class="nav-group-toggle @(isAdminGroup ? "open" : "")" data-bs-toggle="collapse" data-bs-target="#menu-admin">
                <i class="bi bi-person-badge-fill"></i>
                <span>운영자 관리</span>
                <i class="bi bi-chevron-right toggle-icon"></i>
            </div>
            <div id="menu-admin" class="nav-sub collapse @(isAdminGroup ? "show" : "")">
                <a class="nav-link @(currentCtrl == "Event" ? "active" : "")" href="/Event">
                    <i class="bi bi-megaphone-fill"></i> 이벤트/공지
                </a>
            </div>
        </div>
        <div class="nav-section">
            <div class="nav-label">유저 관리</div>
            <div class="nav-group-toggle @(isUserGroup ? "open" : "")" data-bs-toggle="collapse" data-bs-target="#menu-user">
                <i class="bi bi-people-fill"></i>
                <span>유저 관리</span>
                <i class="bi bi-chevron-right toggle-icon"></i>
            </div>
            <div id="menu-user" class="nav-sub collapse @(isUserGroup ? "show" : "")">
                <a class="nav-link @(currentCtrl == "User" ? "active" : "")" href="/User">
                    <i class="bi bi-person-lines-fill"></i> 유저 데이터
                </a>
                <a class="nav-link @(currentCtrl == "GameData" ? "active" : "")" href="/GameData">
                    <i class="bi bi-joystick"></i> 게임 데이터
                </a>
            </div>
        </div>
        <div class="nav-section">
            <div class="nav-label">혈맹 관리</div>
            <div class="nav-group-toggle @(isClanGroup ? "open" : "")" data-bs-toggle="collapse" data-bs-target="#menu-clan">
                <i class="bi bi-shield-shaded"></i>
                <span>혈맹 관리</span>
                <i class="bi bi-chevron-right toggle-icon"></i>
            </div>
            <div id="menu-clan" class="nav-sub collapse @(isClanGroup ? "show" : "")">
                <a class="nav-link @(currentCtrl == "Clan" ? "active" : "")" href="/Clan">
                    <i class="bi bi-flag-fill"></i> 혈맹 데이터
                </a>
            </div>
        </div>
        <div class="nav-section" style="border-bottom: none;">
            <div class="nav-label">시스템</div>
            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Monitoring" ? "active" : "")" href="/Monitoring">
                <i class="bi bi-activity"></i> 모니터링/로그
            </a>
            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "AdminLog" ? "active" : "")" href="/AdminLog">
                <i class="bi bi-shield-lock"></i> 어드민 로그
            </a>
        </div>
        <div style="padding: 16px 20px; border-top: 1px solid #1a2535; margin-top: 16px;">
            <div style="color: #8fa8c0; font-size: 0.75rem;"><i class="bi bi-person-circle me-1"></i> op_001 (운영자)</div>
            <div style="color: #4a6480; font-size: 0.7rem; margin-top: 2px;">최고 관리자</div>
        </div>
    </nav>

    <div id="main-content">
        <header id="topbar">
            <h6 class="page-title">@(ViewData["Title"] ?? "대시보드")</h6>
            <div class="operator-info">
                <span class="badge bg-success">LIVE</span>
                <span>전체 서버 운영 중</span>
                <span>|</span>
                <i class="bi bi-clock me-1"></i>
                <span id="current-time"></span>
            </div>
        </header>

        <div class="page-body">
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible alert-toast" role="alert">
                    <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible alert-toast" role="alert">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @RenderBody()
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.8/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.8/js/dataTables.bootstrap5.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
    <script>
        // 아코디언 토글 아이콘 동기화
        document.querySelectorAll('[data-bs-toggle="collapse"]').forEach(function(toggle) {
            var target = document.querySelector(toggle.getAttribute('data-bs-target'));
            if (target) {
                target.addEventListener('show.bs.collapse', function() { toggle.classList.add('open'); });
                target.addEventListener('hide.bs.collapse', function() { toggle.classList.remove('open'); });
            }
        });

        function updateClock() {
            var now = new Date();
            var el = document.getElementById('current-time');
            if (el) el.textContent = now.toLocaleTimeString('ko-KR');
        }
        updateClock();
        setInterval(updateClock, 1000);
        setTimeout(function () {
            document.querySelectorAll('.alert-toast').forEach(function (el) {
                var a = bootstrap.Alert.getOrCreateInstance(el);
                if (a) a.close();
            });
        }, 4000);
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
