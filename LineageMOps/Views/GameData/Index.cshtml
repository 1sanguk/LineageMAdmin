@model LineageMOps.Models.ViewModels.PaginatedList<LineageMOps.Models.Domain.Character>
@{
    ViewData["Title"] = "게임 데이터 - 캐릭터";
    string? q = ViewBag.Query;
    string? server = ViewBag.Server;
    string? cls = ViewBag.Class;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="mb-0 fw-bold">캐릭터 목록</h5>
    <span class="text-muted" style="font-size:0.85rem;">총 <strong>@Model.TotalCount</strong>개 캐릭터</span>
</div>

<div class="card mb-3">
    <div class="card-body py-3">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-md-4">
                <label class="form-label small fw-semibold text-muted">캐릭터명 검색</label>
                <input type="text" name="q" value="@q" class="form-control form-control-sm" placeholder="캐릭터명 입력" />
            </div>
            <div class="col-md-3">
                <label class="form-label small fw-semibold text-muted">서버</label>
                <select name="server" class="form-select form-select-sm">
                    <option value="">전체 서버</option>
                    @foreach (var s in new[] { "켄라우헬","바츠","기란","오렌","아덴","글루디오","디온" })
                    {
                        <option value="@s" selected="@(server == s ? "selected" : null)">@s</option>
                    }
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label small fw-semibold text-muted">직업</label>
                <select name="cls" class="form-select form-select-sm">
                    <option value="">전체 직업</option>
                    @foreach (LineageMOps.Models.Domain.CharacterClass c in Enum.GetValues(typeof(LineageMOps.Models.Domain.CharacterClass)))
                    {
                        var label = c switch
                        {
                            LineageMOps.Models.Domain.CharacterClass.Knight => "군주",
                            LineageMOps.Models.Domain.CharacterClass.DarkKnight => "기사",
                            LineageMOps.Models.Domain.CharacterClass.Elf => "요정",
                            LineageMOps.Models.Domain.CharacterClass.Wizard => "마법사",
                            LineageMOps.Models.Domain.CharacterClass.DarkElf => "다크엘프",
                            LineageMOps.Models.Domain.CharacterClass.DragonKnight => "드래곤나이트",
                            LineageMOps.Models.Domain.CharacterClass.Illusionist => "환술사",
                            _ => c.ToString()
                        };
                        <option value="@c" selected="@(cls == c.ToString() ? "selected" : null)">@label</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-primary btn-sm w-100">
                    <i class="bi bi-search me-1"></i>검색
                </button>
            </div>
        </form>
    </div>
</div>

<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th class="ps-3">캐릭터명</th>
                        <th>직업</th>
                        <th>서버</th>
                        <th>레벨</th>
                        <th>경험치</th>
                        <th>혈맹</th>
                        <th>아데나</th>
                        <th>마지막 플레이</th>
                        <th class="text-center">관리</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var ch in Model.Items)
                    {
                        var className = ch.Class switch
                        {
                            LineageMOps.Models.Domain.CharacterClass.Knight => "군주",
                            LineageMOps.Models.Domain.CharacterClass.DarkKnight => "기사",
                            LineageMOps.Models.Domain.CharacterClass.Elf => "요정",
                            LineageMOps.Models.Domain.CharacterClass.Wizard => "마법사",
                            LineageMOps.Models.Domain.CharacterClass.DarkElf => "다크엘프",
                            LineageMOps.Models.Domain.CharacterClass.DragonKnight => "드래곤나이트",
                            LineageMOps.Models.Domain.CharacterClass.Illusionist => "환술사",
                            _ => ch.Class.ToString()
                        };
                        var expPct = ch.MaxExperience > 0 ? (int)((double)ch.Experience / ch.MaxExperience * 100) : 0;
                        <tr>
                            <td class="ps-3 fw-semibold">@ch.Name</td>
                            <td><span class="badge bg-secondary">@className</span></td>
                            <td><span class="badge bg-dark">@ch.Server</span></td>
                            <td><strong>@ch.Level</strong></td>
                            <td>
                                <div class="d-flex align-items-center gap-1">
                                    <div class="progress flex-grow-1" style="height:6px;min-width:60px;">
                                        <div class="progress-bar bg-primary" style="width:@expPct%"></div>
                                    </div>
                                    <small class="text-muted">@expPct%</small>
                                </div>
                            </td>
                            <td class="text-muted" style="font-size:0.82rem;">@(string.IsNullOrEmpty(ch.ClanName) ? "-" : ch.ClanName)</td>
                            <td class="text-muted" style="font-size:0.82rem;">@ch.Adena.ToString("N0")</td>
                            <td class="text-muted" style="font-size:0.8rem;">@ch.LastPlayedAt.ToString("MM-dd HH:mm")</td>
                            <td class="text-center">
                                <a href="/GameData/Detail/@ch.Id" class="btn btn-xs btn-outline-info" style="font-size:0.75rem;padding:2px 8px;">상세</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@if (Model.TotalPages > 1)
{
    <nav class="mt-3 d-flex justify-content-center">
        <ul class="pagination pagination-sm">
            <li class="page-item @(!Model.HasPreviousPage ? "disabled" : "")">
                <a class="page-link" href="?q=@q&server=@server&cls=@cls&page=@(Model.PageIndex - 1)">이전</a>
            </li>
            @for (int i = Math.Max(1, Model.PageIndex - 2); i <= Math.Min(Model.TotalPages, Model.PageIndex + 2); i++)
            {
                <li class="page-item @(i == Model.PageIndex ? "active" : "")">
                    <a class="page-link" href="?q=@q&server=@server&cls=@cls&page=@i">@i</a>
                </li>
            }
            <li class="page-item @(!Model.HasNextPage ? "disabled" : "")">
                <a class="page-link" href="?q=@q&server=@server&cls=@cls&page=@(Model.PageIndex + 1)">다음</a>
            </li>
        </ul>
    </nav>
}
