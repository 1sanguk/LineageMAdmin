@using LineageMOps.Constants
@model LineageMOps.Models.ViewModels.PaginatedList<LineageMOps.Models.Domain.Clan>
@{
    ViewData["Title"] = "혈맹 데이터";
    string? q      = ViewBag.Query;
    string? server = ViewBag.Server;
    int?    level  = ViewBag.Level;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="mb-0 fw-bold">혈맹 목록</h5>
    <span class="text-muted" style="font-size:0.85rem;">총 <strong>@Model.TotalCount</strong>개 혈맹</span>
</div>

<div class="card mb-3">
    <div class="card-body py-3">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-md-4">
                <label class="form-label small fw-semibold text-muted">혈맹명 / 혈주명 검색</label>
                <input type="text" name="q" value="@q" class="form-control form-control-sm" placeholder="혈맹명 또는 혈주명 입력" />
            </div>
            <div class="col-md-3">
                <label class="form-label small fw-semibold text-muted">서버</label>
                <select name="server" class="form-select form-select-sm">
                    <option value="">전체 서버</option>
                    @foreach (var s in GameConstants.ServerNames)
                    {
                        <option value="@s" selected="@(server == s ? "selected" : null)">@s</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label small fw-semibold text-muted">혈맹 레벨</label>
                <select name="level" class="form-select form-select-sm">
                    <option value="">전체</option>
                    @for (int lv = 10; lv >= 1; lv--)
                    {
                        <option value="@lv" selected="@(level == lv ? "selected" : null)">Lv.@lv</option>
                    }
                </select>
            </div>
            <div class="col-md-3">
                <button type="submit" class="btn btn-primary btn-sm w-100">
                    <i class="bi bi-search me-1"></i>검색
                </button>
            </div>
        </form>
    </div>
</div>

<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th class="ps-3">혈맹명</th>
                        <th>서버</th>
                        <th>레벨</th>
                        <th>혈주</th>
                        <th>인원 (아카데미)</th>
                        <th>명성치</th>
                        <th>전쟁 전적</th>
                        <th>보유 현황</th>
                        <th>창설일</th>
                        <th class="text-center">관리</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var clan in Model.Items)
                    {
                        var lvColor      = clan.Level >= 9 ? "danger" : clan.Level >= 7 ? "warning text-dark"
                                         : clan.Level >= 5 ? "primary" : "secondary";
                        var memberCount  = clan.MemberCount;
                        var academyCount = clan.AcademyCount;
                        <tr>
                            <td class="ps-3">
                                <span class="fw-semibold">@clan.Emblem @clan.Name</span>
                                @if (clan.IsAtWar) { <span class="badge bg-danger ms-1" style="font-size:0.68rem;">혈맹전</span> }
                            </td>
                            <td><span class="badge bg-dark">@clan.Server</span></td>
                            <td><span class="badge bg-@lvColor">Lv.@clan.Level</span></td>
                            <td class="text-muted" style="font-size:0.85rem;">@clan.LeaderName</td>
                            <td>
                                <span class="fw-semibold">@memberCount</span>
                                <span class="text-muted" style="font-size:0.8rem;">/@clan.MaxMembers</span>
                                @if (clan.HasAcademy && academyCount > 0)
                                {
                                    <span class="text-info ms-1" style="font-size:0.78rem;">(아카데미 @academyCount)</span>
                                }
                            </td>
                            <td class="fw-semibold text-primary">@clan.Reputation.ToString("N0")</td>
                            <td style="font-size:0.83rem;">
                                <span class="text-success fw-semibold">@clan.WarWins W</span>
                                <span class="text-muted">/</span>
                                <span class="text-danger">@clan.WarLosses L</span>
                                <span class="text-muted ms-1">(@clan.WinRate%)</span>
                            </td>
                            <td style="font-size:0.78rem;">
                                @if (clan.HasCastle)
                                {
                                    <span class="badge bg-warning text-dark me-1"><i class="bi bi-building"></i> 성</span>
                                }
                                @if (clan.HasAjit)
                                {
                                    <span class="badge bg-secondary me-1"><i class="bi bi-house-fill"></i> 아지트</span>
                                }
                                @if (clan.HasAcademy)
                                {
                                    <span class="badge bg-info text-dark"><i class="bi bi-mortarboard"></i> 아카데미</span>
                                }
                            </td>
                            <td class="text-muted" style="font-size:0.8rem;">@clan.CreatedAt.ToString("yyyy-MM-dd")</td>
                            <td class="text-center">
                                <a href="/Clan/Detail/@clan.Id" class="btn btn-outline-info" style="font-size:0.75rem;padding:2px 8px;">상세</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@if (Model.TotalPages > 1)
{
    <nav class="mt-3 d-flex justify-content-center">
        <ul class="pagination pagination-sm">
            <li class="page-item @(!Model.HasPreviousPage ? "disabled" : "")">
                <a class="page-link" href="?q=@q&server=@server&level=@level&page=@(Model.PageIndex - 1)">이전</a>
            </li>
            @for (int i = Math.Max(1, Model.PageIndex - 2); i <= Math.Min(Model.TotalPages, Model.PageIndex + 2); i++)
            {
                <li class="page-item @(i == Model.PageIndex ? "active" : "")">
                    <a class="page-link" href="?q=@q&server=@server&level=@level&page=@i">@i</a>
                </li>
            }
            <li class="page-item @(!Model.HasNextPage ? "disabled" : "")">
                <a class="page-link" href="?q=@q&server=@server&level=@level&page=@(Model.PageIndex + 1)">다음</a>
            </li>
        </ul>
    </nav>
}
